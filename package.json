    "@vitejs/plugin-react": "5.1.3",
    "@wxt-dev/auto-icons": "1.1.1",
    "@wxt-dev/module-react": "1.2.2",
    "autoprefixer": "10.5.0",
    "daisyui": "5.5.19",
    "globals": "17.6.0",
    "postcss": "8.5.14",
    "tailwindcss": "4.2.4",
